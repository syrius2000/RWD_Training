sudo mysql_secure_installationsudo mysql -u root -pCREATE USER 'ユーザー名'@'localhost' IDENTIFIED BY 'パスワード';GRANT ALL PRIVILEGES ON データベース名.* TO 'ユーザー名'@'localhost';FLUSH PRIVILEGES;/etc/mysql/mysql.conf.d/mysqld.cnfを編集--------------------[mysqld]character-set-server=utf8mb4collation-server=utf8mb4_general_cidefault-time-zone=+09:00[client]default-character-set=utf8mb4---------------------sudo systemctl restart mysqlhttps://documentation.ubuntu.com/server/how-to/databases/install-mysql/index.html